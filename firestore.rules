rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /trainings/{trainingId} {
      allow read, write: if true;
    }
    match /group_members/{memberId} {
      allow read, write: if true;
    }
  }
}
